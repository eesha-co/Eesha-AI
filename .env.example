# Multi-Agent API Keys (Required)
# Agent 1 — The Specialist (Qwen Coder 480B)
AGENT1_API_KEY=your_nvidia_api_key_here
# Agent 2 — The Critic (Kimi K2 Thinking)
AGENT2_API_KEY=your_nvidia_api_key_here
# Agent 3 — The Judge (Mistral Large 3)
AGENT3_API_KEY=your_nvidia_api_key_here

# Legacy (fallback — if set, used as default for all agents)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Supabase Database (Required)
# Get these from Supabase Dashboard → Settings → Database → Connection string
# Use the "connection pooling" URL for DATABASE_URL (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Use the "direct" URL for DIRECT_URL (port 5432) — needed for Prisma migrations
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Workspace root for file operations
WORKSPACE_ROOT=./workspace
