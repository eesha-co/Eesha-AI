# ══════════════════════════════════════════════════════════════════════════════
# Eesha AI — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  NEVER commit real credentials. Use .env for secrets, this file is a template.

# ─── Multi-Agent API Keys (Required) ─────────────────────────────────────────
AGENT1_API_KEY=your_nvidia_api_key_here
AGENT2_API_KEY=your_nvidia_api_key_here
AGENT3_API_KEY=your_nvidia_api_key_here

# Legacy (fallback)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ─── Supabase Database (Required) ────────────────────────────────────────────
# Pooler URL for runtime (connection pooling)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Direct URL for migrations
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase Service Role (for server-side operations)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ─── NextAuth Configuration (Required) ───────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-domain.com

# ─── Authentication Providers ─────────────────────────────────────────────────
# GitHub OAuth (Required): https://github.com/settings/developers
GITHUB_ID=your_github_client_id
GITHUB_SECRET=your_github_client_secret

# ─── Email Provider (Required for magic link sign-in) ────────────────────────
# Supports any SMTP provider (Gmail, SendGrid, Resend, etc.)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your_smtp_user
EMAIL_SERVER_PASSWORD=your_smtp_password
EMAIL_FROM=noreply@eesha-ai.com

# ─── Workspace Configuration ─────────────────────────────────────────────────
WORKSPACE_ROOT=./workspace
